{
  "$schema": "https://json.schemastore.org/claude-code-settings.json",
  "permissions": {
    "allow": [
      "Read(*)",
      "Glob(*)",
      "Grep(*)",
      "Edit(*)",
      "Write(*)",
      "Bash(git status:*)",
      "Bash(git diff:*)",
      "Bash(git log:*)",
      "Bash(git show:*)",
      "Bash(git branch:*)",
      "Bash(git add:*)",
      "Bash(git commit:*)",
      "Bash(ls:*)",
      "Bash(mkdir:*)",
      "Bash(cp:*)",
      "Bash(mv:*)",
      "Bash(cat:*)",
      "Bash(head:*)",
      "Bash(tail:*)",
      "Bash(wc:*)",
      "Bash(file:*)",
      "WebFetch(domain:images.unsplash.com)",
      "WebFetch(domain:storage.googleapis.com)",
      "WebFetch(domain:unsplash.com)"
    ],
    "deny": [
      "Bash(rm -rf:*)",
      "Bash(rm -fr:*)",
      "Bash(git push --force:*)",
      "Bash(git push -f:*)",
      "Bash(git push --force-with-lease:*)",
      "Bash(git reset --hard:*)",
      "Bash(git clean -fd:*)",
      "Bash(git clean -f:*)",
      "Bash(git checkout -- :*)",
      "Bash(git checkout . :*)",
      "Bash(git branch -D:*)",
      "Edit(netlify.toml)",
      "Edit(netlify/functions/submit.js)",
      "Write(netlify.toml)",
      "Write(netlify/functions/submit.js)"
    ]
  },
  "hooks": {
    "SessionStart": [
      {
        "matcher": "startup|resume",
        "hooks": [
          {
            "type": "command",
            "command": "echo '=== site state ===' && git status --short 2>/dev/null || true; echo '--- last commit ---'; git log -1 --oneline 2>/dev/null || true"
          }
        ]
      }
    ],
    "PostToolUse": [
      {
        "matcher": "Edit|Write",
        "hooks": [
          {
            "type": "command",
            "command": "[ -f \"$SITE_BUILDER_HOME/bin/check-partial-drift.mjs\" ] && node \"$SITE_BUILDER_HOME/bin/check-partial-drift.mjs\" || true"
          }
        ]
      }
    ]
  }
}
